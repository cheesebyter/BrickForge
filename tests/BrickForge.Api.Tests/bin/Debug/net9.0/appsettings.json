{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "BrickForge.Api.Services": "Debug",
      "BrickForge.BrickGraph.Repair": "Debug"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "AllowedHosts": "localhost",
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://localhost:5000" },
      "Https": { "Url": "https://localhost:5001" }
    }
  },
  "Generation": {
    "MaxParts": 300,
    "DefaultTargetParts": 180,
    "OutputRoot": "data/outputs"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "PlanningModel": "qwen2.5-coder:14b",
    "FallbackModel": "llama3.1:8b",
    "TimeoutSeconds": 120,
    "Temperature": 0.2,
    "MockMode": false
  },
  "ExternalAi": {
    "Enabled": false,
    "MaxCostPerJob": 0,
    "LogExternalUsage": true
  },
  "Export": {
    "GenerateMpd": true,
    "GenerateCsv": true,
    "GenerateMarkdown": true
  }
}
